<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Finansal_app.Screens.Register"
             Title="Register">
    <VerticalStackLayout>
        <Label 
            Text="Wellcome to Finansial app! Make your registration below."
            VerticalOptions="Center" 
            HorizontalOptions="Center" 
            FontSize="20"/>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="15">
                <Label 
                    Text="Full name"
                    VerticalOptions="Center" 
                    HorizontalOptions="Start" 
                    FontSize="16"/>
                <Entry x:Name="NameEntry" Keyboard="Text"  WidthRequest="250" HorizontalOptions="Center"/>
                <Label 
                    Text="Email"
                    VerticalOptions="Center" 
                    HorizontalOptions="Start" 
                    FontSize="16"/>
                <Entry x:Name="EmailEntry" Keyboard="Email"  WidthRequest="250" HorizontalOptions="Center"/>
                <Label 
                    Text="Password"
                    VerticalOptions="Center" 
                    HorizontalOptions="Start" 
                    FontSize="16"/>
                <Entry x:Name="PasswordEntry" IsPassword="True" WidthRequest="250" HorizontalOptions="Center"/>
                <Label 
                    Text="Repeat password"
                    VerticalOptions="Center" 
                    HorizontalOptions="Start" 
                    FontSize="16"/>
                <Entry x:Name="RepassEntry"  IsPassword="True" WidthRequest="250" HorizontalOptions="Center"/>
                <Button Text="Register" Clicked="OnRegister" BackgroundColor="SkyBlue" TextColor="White"/>
            </VerticalStackLayout>
        </ScrollView>
    </VerticalStackLayout>
</ContentPage>