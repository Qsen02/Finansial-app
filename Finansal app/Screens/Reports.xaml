<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Finansal_app.Screens.Reports"
             Title="Reports">
    <VerticalStackLayout>
        <Grid>
            <Button Text="&#xf060;" Clicked="OnBack" FontSize="22" FontFamily="FontAwesomeSolid" BackgroundColor="{AppThemeBinding Light=SkyBlue, Dark=DeepSkyBlue}" TextColor="Black" FontAttributes="Bold" HorizontalOptions="Start"/>
            <Label 
                Text="Your report for all transactions these month"
                VerticalOptions="Center" 
                HorizontalOptions="Center" FontSize="22"/>     
        </Grid>
    </VerticalStackLayout>
</ContentPage>