<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Finansal_app.Screens.MakeExpense"
             Title="Make Expense">
    <VerticalStackLayout Padding="30" Spacing="20" HorizontalOptions="Center" VerticalOptions="Center">
        <Label Text="Make expense here" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center"/>
        <ScrollView>
            <VerticalStackLayout HorizontalOptions="Center" Spacing="20" Padding="30">
                <Label Text="Description" FontSize="16" HorizontalOptions="Center"/>
                <Entry x:Name="Description" Keyboard="Text" WidthRequest="500"/>
                <Label Text="Price" FontSize="16" HorizontalOptions="Center"/>
                <Entry x:Name="Price" Keyboard="Numeric" WidthRequest="500"/>
                <Label Text="Category:" FontSize="16" HorizontalOptions="Center"/>
                <Picker x:Name="Category"  WidthRequest="500">
                    <Picker.Items>
                        <x:String>All</x:String>
                        <x:String>Food</x:String>
                        <x:String>Technologies</x:String>
                        <x:String>Clothes</x:String>
                        <x:String>Travels</x:String>
                        <x:String>Education</x:String>
                    </Picker.Items>
                </Picker>
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="30">
                    <Button Text="Create" Clicked="CreateExpense"  BackgroundColor="{AppThemeBinding Light=SkyBlue, Dark=DeepSkyBlue}" TextColor="Black" MaximumWidthRequest="100" FontAttributes="Bold"/>
                    <Button Text="Cancel" Clicked="OnCancel"  BackgroundColor="{AppThemeBinding Light=SkyBlue, Dark=DeepSkyBlue}" TextColor="Black" MaximumWidthRequest="100" FontAttributes="Bold"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </VerticalStackLayout>
</ContentPage>