<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Finansal_app.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Finansal_app.Screens"
    Title="Finansal_app">
    
    <ShellContent
     Title="Register"
     ContentTemplate="{DataTemplate local:Register}"
     Route="Register" />
    <ShellContent
      Title="Login"
      ContentTemplate="{DataTemplate local:Login}"
      Route="Login" />
    <ShellContent
      Title="Home"
      ContentTemplate="{DataTemplate local:Home}"
      Route="Home" />
    <ShellContent
      Title="Make Incame"
      ContentTemplate="{DataTemplate local:MakeIncame}"
      Route="MakeIncame" />
    <ShellContent
      Title="Make Expense"
      ContentTemplate="{DataTemplate local:MakeExpense}"
      Route="MakeExpense" />
    <ShellContent
    Title="Transactions"
    ContentTemplate="{DataTemplate local:Transactions}"
    Route="Transactions" />
</Shell>
